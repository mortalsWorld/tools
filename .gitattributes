# 统一换行符策略：所有文本文件使用 LF
# 这样可以确保跨平台一致性

# 源代码文件 - 使用 LF
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.html        text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.svg         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf

# Windows 特定文件 - 使用 CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# 二进制文件不进行转换
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.exe         binary
*.dll         binary
*.pak         binary
*.bin         binary

# Node.js 特殊处理
package-lock.json -text
